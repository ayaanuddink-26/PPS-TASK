def weather_harvest_system():
    print("--- Crop Harvest Advisory System ---")
    
    # 1. Get the number of days (Constraint: 3 to 7)
    try:
        n = int(input("Enter number of days to analyze (3-7): "))
        if not (3 <= n <= 7):
            print("Error: Please enter a value between 3 and 7.")
            return
    except ValueError:
        print("Error: Invalid input. Please enter a number.")
        return

    rainfall_records = []
    humidity_records = []

    # 2. Collect Data (Batch Input)
    print(f"\nEnter data for the last {n} days:")
    for i in range(1, n + 1):
        while True:
            try:
                rain = float(input(f" Day {i} Rainfall (0-50mm): "))
                hum = float(input(f" Day {i} Humidity (0-100%): "))
                
                # Check constraints
                if 0 <= rain <= 50 and 0 <= hum <= 100:
                    rainfall_records.append(rain)
                    humidity_records.append(hum)
                    break
                else:
                    print(" Out of range! Rain: 0-50, Humidity: 0-100. Try again.")
            except ValueError:
                print(" Invalid input. Enter numeric values.")

    # 3. Calculate Averages (Core Requirement)
    avg_rain = sum(rainfall_records) / n
    avg_hum = sum(humidity_records) / n

    # 4. Decision Logic
    # Thresholds: Rainfall > 5mm OR Humidity > 70% results in a delay
    if avg_rain > 5.0 or avg_hum > 70.0:
        advisory = "Delay Harvest"
        note = "Risk of post-harvest loss due to moisture."
    else:
        advisory = "Harvest Now"
        note = "Conditions are safe for harvesting."

    # 5. Output Results
    print("\n" + "="*30)
    print(f"RESULTS FOR {n}-DAY TREND")
    print("="*30)
    print(f"Average Rainfall: {avg_rain:.2f} mm")
    print(f"Average Humidity: {avg_hum:.2f}%")
    print(f"Advisory: {advisory}")
    print(f"Note: {note}")
    print("="*30)

if __name__ == "__main__":
    weather_harvest_system()
